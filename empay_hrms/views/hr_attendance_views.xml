<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ============================================================ -->
    <!-- Attendance Search View (Standalone for Odoo 19)              -->
    <!-- ============================================================ -->
    <record id="view_attendance_search_empay" model="ir.ui.view">
        <field name="name">hr.attendance.search.empay</field>
        <field name="model">hr.attendance</field>
        <field name="priority">50</field>
        <field name="arch" type="xml">
            <search string="Search Attendance">
                <field name="employee_id"/>
                <field name="status"/>
                <separator/>
                <filter string="Present" name="filter_present"
                        domain="[('status', '=', 'present')]"/>
                <filter string="Half Day" name="filter_half_day"
                        domain="[('status', '=', 'half_day')]"/>
                <filter string="Absent" name="filter_absent"
                        domain="[('status', '=', 'absent')]"/>
                <separator/>
                <filter string="Current Month" name="filter_current_month"
                        domain="[('check_in', '&gt;=', (context_today()).strftime('%%Y-%%m-01'))]"/>
            </search>
        </field>
    </record>

    <!-- ============================================================ -->
    <!-- Attendance Pivot View                                         -->
    <!-- ============================================================ -->
    <record id="view_attendance_pivot_empay" model="ir.ui.view">
        <field name="name">hr.attendance.pivot.empay</field>
        <field name="model">hr.attendance</field>
        <field name="arch" type="xml">
            <pivot string="Attendance Summary">
                <field name="employee_id" type="row"/>
                <field name="check_in" type="col" interval="month"/>
                <field name="worked_hours" type="measure"/>
                <field name="overtime_hours" type="measure"/>
                <field name="late_minutes" type="measure"/>
            </pivot>
        </field>
    </record>

    <!-- ============================================================ -->
    <!-- Attendance Graph View                                         -->
    <!-- ============================================================ -->
    <record id="view_attendance_graph_empay" model="ir.ui.view">
        <field name="name">hr.attendance.graph.empay</field>
        <field name="model">hr.attendance</field>
        <field name="arch" type="xml">
            <graph string="Attendance Overview" type="bar">
                <field name="employee_id"/>
                <field name="worked_hours" type="measure"/>
            </graph>
        </field>
    </record>

    <!-- ============================================================ -->
    <!-- Attendance Actions                                            -->
    <!-- ============================================================ -->
    <record id="action_empay_my_attendance" model="ir.actions.act_window">
        <field name="name">My Attendance</field>
        <field name="res_model">hr.attendance</field>
        <field name="view_mode">list,form</field>
        <field name="domain">[('employee_id.user_id', '=', uid)]</field>
        <field name="context">{'search_default_filter_current_month': 1}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                No attendance records yet. Check in to start!
            </p>
        </field>
    </record>

    <record id="action_empay_all_attendance" model="ir.actions.act_window">
        <field name="name">All Attendance</field>
        <field name="res_model">hr.attendance</field>
        <field name="view_mode">list,pivot,graph,form</field>
        <field name="context">{'search_default_filter_current_month': 1}</field>
    </record>

    <record id="action_empay_attendance_reports" model="ir.actions.act_window">
        <field name="name">Attendance Reports</field>
        <field name="res_model">hr.attendance</field>
        <field name="view_mode">pivot,graph,list</field>
    </record>

</odoo>
