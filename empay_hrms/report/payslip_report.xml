<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ============================================================ -->
    <!-- Payslip Report Action                                         -->
    <!-- ============================================================ -->
    <record id="action_report_payslip_empay" model="ir.actions.report">
        <field name="name">EmPay Payslip</field>
        <field name="model">empay.payslip</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">empay_hrms.report_payslip_empay_template</field>
        <field name="report_file">empay_hrms.report_payslip_empay_template</field>
        <field name="print_report_name">'EmPay_Payslip_%s_%s' % (object.employee_id.name, object.date_from)</field>
        <field name="binding_model_id" ref="empay_hrms.model_empay_payslip"/>
        <field name="binding_type">report</field>
    </record>

</odoo>
