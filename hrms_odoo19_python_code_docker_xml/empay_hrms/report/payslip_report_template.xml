<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <template id="report_payslip_empay_template">
            <t t-call="web.html_container">
                <t t-foreach="docs" t-as="o">
                    <t t-call="web.external_layout">
                        <div class="page" style="font-family: 'Segoe UI', Arial, sans-serif;">

                            <!-- Header Section -->
                            <div style="display: flex; justify-content: space-between; align-items: center; border-bottom: 3px solid #1a4a5e; padding-bottom: 15px; margin-bottom: 20px;">
                                <div>
                                    <h2 style="color: #1a4a5e; margin: 0;">
                                        <t t-esc="o.company_id.name"/>
                                    </h2>
                                    <p style="margin: 5px 0 0; color: #666;">
                                        <t t-esc="o.company_id.street or ''"/>
                                        <t t-if="o.company_id.city">, <t t-esc="o.company_id.city"/></t>
                                    </p>
                                </div>
                                <div style="text-align: right;">
                                    <h1 style="color: #00b9a1; margin: 0; font-size: 28px;">PAYSLIP</h1>
                                    <p style="margin: 5px 0 0; color: #666; font-size: 14px;">
                                        <t t-esc="o.date_from" t-options="{'widget': 'date'}"/>
                                        to
                                        <t t-esc="o.date_to" t-options="{'widget': 'date'}"/>
                                    </p>
                                </div>
                            </div>

                            <!-- Employee Details -->
                            <table style="width: 100%; margin-bottom: 20px; border-collapse: collapse;">
                                <tr>
                                    <td style="width: 50%; vertical-align: top; padding: 10px; background: #f8f9fa; border-radius: 5px;">
                                        <table style="width: 100%;">
                                            <tr>
                                                <td style="font-weight: bold; color: #1a4a5e; padding: 4px 8px;">Employee Name:</td>
                                                <td style="padding: 4px 8px;"><t t-esc="o.employee_id.name"/></td>
                                            </tr>
                                            <tr>
                                                <td style="font-weight: bold; color: #1a4a5e; padding: 4px 8px;">EmPay ID:</td>
                                                <td style="padding: 4px 8px;"><t t-esc="o.employee_id.empay_employee_id or 'N/A'"/></td>
                                            </tr>
                                            <tr>
                                                <td style="font-weight: bold; color: #1a4a5e; padding: 4px 8px;">Department:</td>
                                                <td style="padding: 4px 8px;"><t t-esc="o.employee_id.department_id.name or 'N/A'"/></td>
                                            </tr>
                                        </table>
                                    </td>
                                    <td style="width: 10px;"/>
                                    <td style="width: 50%; vertical-align: top; padding: 10px; background: #f8f9fa; border-radius: 5px;">
                                        <table style="width: 100%;">
                                            <tr>
                                                <td style="font-weight: bold; color: #1a4a5e; padding: 4px 8px;">Designation:</td>
                                                <td style="padding: 4px 8px;"><t t-esc="o.employee_id.job_title or 'N/A'"/></td>
                                            </tr>
                                            <tr>
                                                <td style="font-weight: bold; color: #1a4a5e; padding: 4px 8px;">Bank Account:</td>
                                                <td style="padding: 4px 8px;"><t t-esc="o.employee_id.bank_account_number or 'N/A'"/></td>
                                            </tr>
                                            <tr>
                                                <td style="font-weight: bold; color: #1a4a5e; padding: 4px 8px;">Pay Period:</td>
                                                <td style="padding: 4px 8px;">
                                                    <t t-esc="o.date_from" t-options="{'widget': 'date'}"/> -
                                                    <t t-esc="o.date_to" t-options="{'widget': 'date'}"/>
                                                </td>
                                            </tr>
                                        </table>
                                    </td>
                                </tr>
                            </table>

                            <!-- Attendance Summary -->
                            <h3 style="color: #1a4a5e; border-bottom: 2px solid #e0e0e0; padding-bottom: 8px;">Attendance Summary</h3>
                            <table style="width: 100%; border-collapse: collapse; margin-bottom: 20px;">
                                <thead>
                                    <tr style="background: #1a4a5e; color: white;">
                                        <th style="padding: 8px 12px; text-align: center;">Working Days</th>
                                        <th style="padding: 8px 12px; text-align: center;">Present Days</th>
                                        <th style="padding: 8px 12px; text-align: center;">Half Days</th>
                                        <th style="padding: 8px 12px; text-align: center;">Leave Days</th>
                                        <th style="padding: 8px 12px; text-align: center;">Absent Days</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <tr>
                                        <td style="padding: 8px 12px; text-align: center; border: 1px solid #dee2e6;">
                                            <t t-esc="o.total_working_days"/>
                                        </td>
                                        <td style="padding: 8px 12px; text-align: center; border: 1px solid #dee2e6;">
                                            <t t-esc="o.present_days"/>
                                        </td>
                                        <td style="padding: 8px 12px; text-align: center; border: 1px solid #dee2e6;">
                                            <t t-esc="o.half_days"/>
                                        </td>
                                        <td style="padding: 8px 12px; text-align: center; border: 1px solid #dee2e6;">
                                            <t t-esc="o.leave_days"/>
                                        </td>
                                        <td style="padding: 8px 12px; text-align: center; border: 1px solid #dee2e6;">
                                            <t t-esc="o.absent_days"/>
                                        </td>
                                    </tr>
                                </tbody>
                            </table>

                            <!-- Earnings and Deductions side by side -->
                            <table style="width: 100%; margin-bottom: 20px;">
                                <tr>
                                    <td style="width: 48%; vertical-align: top;">
                                        <h3 style="color: #1a4a5e; border-bottom: 2px solid #e0e0e0; padding-bottom: 8px;">Earnings</h3>
                                        <table style="width: 100%; border-collapse: collapse;">
                                            <thead>
                                                <tr style="background: #e8f5e9;">
                                                    <th style="padding: 8px 12px; text-align: left;">Component</th>
                                                    <th style="padding: 8px 12px; text-align: right;">Amount (₹)</th>
                                                </tr>
                                            </thead>
                                            <tbody>
                                                <tr>
                                                    <td style="padding: 6px 12px; border-bottom: 1px solid #eee;">Basic Salary (Prorated)</td>
                                                    <td style="padding: 6px 12px; text-align: right; border-bottom: 1px solid #eee;">
                                                        <t t-esc="'%.2f' % o.prorated_basic"/>
                                                    </td>
                                                </tr>
                                                <tr>
                                                    <td style="padding: 6px 12px; border-bottom: 1px solid #eee;">HRA (40%)</td>
                                                    <td style="padding: 6px 12px; text-align: right; border-bottom: 1px solid #eee;">
                                                        <t t-esc="'%.2f' % o.hra"/>
                                                    </td>
                                                </tr>
                                                <tr>
                                                    <td style="padding: 6px 12px; border-bottom: 1px solid #eee;">Transport Allowance</td>
                                                    <td style="padding: 6px 12px; text-align: right; border-bottom: 1px solid #eee;">
                                                        <t t-esc="'%.2f' % o.transport_allowance"/>
                                                    </td>
                                                </tr>
                                                <tr style="font-weight: bold; background: #e8f5e9;">
                                                    <td style="padding: 8px 12px;">Gross Salary</td>
                                                    <td style="padding: 8px 12px; text-align: right;">
                                                        <t t-esc="'%.2f' % o.gross_salary"/>
                                                    </td>
                                                </tr>
                                            </tbody>
                                        </table>
                                    </td>
                                    <td style="width: 4%;"/>
                                    <td style="width: 48%; vertical-align: top;">
                                        <h3 style="color: #1a4a5e; border-bottom: 2px solid #e0e0e0; padding-bottom: 8px;">Deductions</h3>
                                        <table style="width: 100%; border-collapse: collapse;">
                                            <thead>
                                                <tr style="background: #ffebee;">
                                                    <th style="padding: 8px 12px; text-align: left;">Component</th>
                                                    <th style="padding: 8px 12px; text-align: right;">Amount (₹)</th>
                                                </tr>
                                            </thead>
                                            <tbody>
                                                <tr>
                                                    <td style="padding: 6px 12px; border-bottom: 1px solid #eee;">PF (Employee - 12%)</td>
                                                    <td style="padding: 6px 12px; text-align: right; border-bottom: 1px solid #eee;">
                                                        <t t-esc="'%.2f' % o.pf_employee"/>
                                                    </td>
                                                </tr>
                                                <tr>
                                                    <td style="padding: 6px 12px; border-bottom: 1px solid #eee;">Professional Tax</td>
                                                    <td style="padding: 6px 12px; text-align: right; border-bottom: 1px solid #eee;">
                                                        <t t-esc="'%.2f' % o.professional_tax"/>
                                                    </td>
                                                </tr>
                                                <tr style="color: #888;">
                                                    <td style="padding: 6px 12px; border-bottom: 1px solid #eee;">PF (Employer - 12%) *</td>
                                                    <td style="padding: 6px 12px; text-align: right; border-bottom: 1px solid #eee;">
                                                        <t t-esc="'%.2f' % o.pf_employer"/>
                                                    </td>
                                                </tr>
                                                <tr style="font-weight: bold; background: #ffebee;">
                                                    <td style="padding: 8px 12px;">Total Deductions</td>
                                                    <td style="padding: 8px 12px; text-align: right;">
                                                        <t t-esc="'%.2f' % (o.pf_employee + o.professional_tax)"/>
                                                    </td>
                                                </tr>
                                            </tbody>
                                        </table>
                                    </td>
                                </tr>
                            </table>

                            <!-- Net Pay Box -->
                            <div style="background: linear-gradient(135deg, #1a4a5e, #00b9a1); color: white; padding: 20px; border-radius: 8px; text-align: center; margin: 20px 0;">
                                <h2 style="margin: 0; font-size: 18px;">NET PAY</h2>
                                <h1 style="margin: 10px 0 0; font-size: 36px;">
                                    ₹ <t t-esc="'%.2f' % o.net_salary"/>
                                </h1>
                            </div>

                            <!-- Employer PF Note -->
                            <p style="color: #888; font-size: 11px; margin-top: 5px;">
                                * Employer PF contribution is informational and not deducted from employee salary.
                            </p>

                            <!-- Footer -->
                            <div style="border-top: 2px solid #e0e0e0; margin-top: 30px; padding-top: 15px; text-align: center;">
                                <p style="color: #999; font-size: 12px; margin: 0;">
                                    This is a computer-generated payslip. No signature required.
                                </p>
                                <p style="color: #999; font-size: 11px; margin: 5px 0 0;">
                                    Generated by EmPay HRMS | <t t-esc="o.company_id.name"/>
                                </p>
                            </div>

                        </div>
                    </t>
                </t>
            </t>
        </template>
    </data>
</odoo>
