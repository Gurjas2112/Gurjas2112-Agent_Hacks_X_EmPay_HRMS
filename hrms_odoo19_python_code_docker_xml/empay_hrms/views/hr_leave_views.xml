<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ============================================================ -->
    <!-- Leave Actions                                                 -->
    <!-- ============================================================ -->
    <record id="action_empay_my_leaves" model="ir.actions.act_window">
        <field name="name">My Time Off</field>
        <field name="res_model">hr.leave</field>
        <field name="view_mode">list,form,calendar</field>
        <field name="domain">[('employee_id.user_id', '=', uid)]</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                No leave requests yet. Apply for time off!
            </p>
        </field>
    </record>

    <record id="action_empay_leave_requests" model="ir.actions.act_window">
        <field name="name">Leave Requests</field>
        <field name="res_model">hr.leave</field>
        <field name="view_mode">list,form,calendar</field>
    </record>

    <record id="action_empay_leave_allocations" model="ir.actions.act_window">
        <field name="name">Leave Allocations</field>
        <field name="res_model">hr.leave.allocation</field>
        <field name="view_mode">list,form</field>
    </record>

</odoo>
