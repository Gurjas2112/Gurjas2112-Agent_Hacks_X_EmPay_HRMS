<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Customize the Login / Signup Layout -->
    <!-- Customize the Login / Signup Layout (Commented out for Odoo 19 compatibility as we use Flask UI)
    <template id="empay_login_layout" inherit_id="web.login_layout" name="EmPay Login Layout">
        <xpath expr="//div[hasclass('card-body')]" position="before">
            <div class="text-center mb-4 mt-2">
                <img src="/empay_hrms/static/src/img/logo.jpeg" 
                     style="max-height: 80px; width: auto;" 
                     class="mb-2" alt="EmPay Logo"/>
                <h2 style="font-weight: 700; color: #4338ca;">EmPay HRMS</h2>
                <p class="text-muted">Smart Human Resource Management</p>
            </div>
        </xpath>
        <xpath expr="//div[hasclass('o_database_list')]" position="attributes">
            <attribute name="style">border: none; border-radius: 16px; box-shadow: 0 20px 25px -5px rgba(0, 0, 0, 0.1), 0 10px 10px -5px rgba(0, 0, 0, 0.04);</attribute>
        </xpath>
        <xpath expr="//div[hasclass('container')]" position="attributes">
            <attribute name="style">background: linear-gradient(135deg, #f5f7ff 0%, #eef2ff 100%); min-height: 100vh; display: flex; align-items: center;</attribute>
        </xpath>
    </template>
    -->

    <!-- Enhance the Login Form (Commented out for Odoo 19)
    <template id="empay_login" inherit_id="web.login" name="EmPay Login">
        <xpath expr="//button[@type='submit']" position="attributes">
            <attribute name="class">btn btn-primary btn-block w-100 py-2</attribute>
            <attribute name="style">background: linear-gradient(135deg, #4338ca 0%, #312e81 100%); border: none; font-weight: 600; border-radius: 8px;</attribute>
        </xpath>
        <xpath expr="//label[@for='login']" position="attributes">
            <attribute name="style">font-weight: 600; color: #374151;</attribute>
        </xpath>
        <xpath expr="//label[@for='password']" position="attributes">
            <attribute name="style">font-weight: 600; color: #374151;</attribute>
        </xpath>
    </template>
    -->

    <!-- Enhance the Signup Form (Commented out for Odoo 19)
    <template id="empay_signup" inherit_id="auth_signup.signup" name="EmPay Signup">
        <xpath expr="//button[@type='submit']" position="attributes">
            <attribute name="class">btn btn-primary btn-block w-100 py-2</attribute>
            <attribute name="style">background: linear-gradient(135deg, #4338ca 0%, #312e81 100%); border: none; font-weight: 600; border-radius: 8px;</attribute>
        </xpath>
    </template>
    -->

    <!-- Configure Default Settings for Real-time Signup -->
    <record id="base_config_settings_empay" model="res.config.settings">
        <field name="auth_signup_uninvited">b2c</field>
    </record>

    <!-- Execute a function to set the signup mode to 'Free' (b2c) on install -->
    <function model="res.config.settings" name="execute">
        <value model="res.config.settings" eval="obj().create({'auth_signup_uninvited': 'b2c'}).id"/>
    </function>
</odoo>
