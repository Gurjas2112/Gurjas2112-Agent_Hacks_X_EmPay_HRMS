<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="0">

        <!-- ============================================================ -->
        <!--                    SECURITY GROUPS                           -->
        <!-- ============================================================ -->

        <!-- Group 1: Employee (base level) — implied by internal user -->
        <record id="group_employee" model="res.groups">
            <field name="name">Employee</field>
            <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
            <field name="comment">Basic employee access: view own attendance, leaves, and payslips.</field>
        </record>

        <!-- Group 2: HR Officer — implies Employee -->
        <record id="group_hr_officer" model="res.groups">
            <field name="name">HR Officer</field>
            <field name="implied_ids" eval="[(4, ref('empay_hrms.group_employee'))]"/>
            <field name="comment">HR Officer: manage employee profiles, monitor attendance, manage leave allocations.</field>
        </record>

        <!-- Group 3: Payroll Officer — implies Employee -->
        <record id="group_payroll_officer" model="res.groups">
            <field name="name">Payroll Officer</field>
            <field name="implied_ids" eval="[(4, ref('empay_hrms.group_employee'))]"/>
            <field name="comment">Payroll Officer: manage payroll, approve/reject leave, generate reports.</field>
        </record>

        <!-- Group 4: EmPay Admin — implies all three -->
        <record id="group_admin" model="res.groups">
            <field name="name">EmPay Admin</field>
            <field name="implied_ids" eval="[
                (4, ref('empay_hrms.group_employee')),
                (4, ref('empay_hrms.group_hr_officer')),
                (4, ref('empay_hrms.group_payroll_officer'))
            ]"/>
            <field name="comment">Full access to all EmPay modules. No restrictions.</field>
        </record>

        <!-- ============================================================ -->
        <!--              RECORD RULES (ir.rule)                          -->
        <!-- ============================================================ -->

        <!-- =========================== -->
        <!-- ATTENDANCE RECORD RULES     -->
        <!-- =========================== -->

        <!-- Employee: can only read own attendance records -->
        <record id="rule_attendance_employee_own" model="ir.rule">
            <field name="name">EmPay: Employee sees own attendance</field>
            <field name="model_id" ref="hr_attendance.model_hr_attendance"/>
            <field name="domain_force">[('employee_id.user_id', '=', user.id)]</field>
            <field name="groups" eval="[(4, ref('empay_hrms.group_employee'))]"/>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="False"/>
            <field name="perm_create" eval="False"/>
            <field name="perm_unlink" eval="False"/>
        </record>

        <!-- HR Officer: can read/write all attendance records -->
        <record id="rule_attendance_hr_officer_all" model="ir.rule">
            <field name="name">EmPay: HR Officer sees all attendance</field>
            <field name="model_id" ref="hr_attendance.model_hr_attendance"/>
            <field name="domain_force">[(1, '=', 1)]</field>
            <field name="groups" eval="[(4, ref('empay_hrms.group_hr_officer'))]"/>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="True"/>
            <field name="perm_create" eval="True"/>
            <field name="perm_unlink" eval="False"/>
        </record>

        <!-- Payroll Officer: can read all attendance records -->
        <record id="rule_attendance_payroll_officer_all" model="ir.rule">
            <field name="name">EmPay: Payroll Officer sees all attendance</field>
            <field name="model_id" ref="hr_attendance.model_hr_attendance"/>
            <field name="domain_force">[(1, '=', 1)]</field>
            <field name="groups" eval="[(4, ref('empay_hrms.group_payroll_officer'))]"/>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="False"/>
            <field name="perm_create" eval="False"/>
            <field name="perm_unlink" eval="False"/>
        </record>

        <!-- Admin: unrestricted attendance access -->
        <record id="rule_attendance_admin_all" model="ir.rule">
            <field name="name">EmPay: Admin full attendance access</field>
            <field name="model_id" ref="hr_attendance.model_hr_attendance"/>
            <field name="domain_force">[(1, '=', 1)]</field>
            <field name="groups" eval="[(4, ref('empay_hrms.group_admin'))]"/>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="True"/>
            <field name="perm_create" eval="True"/>
            <field name="perm_unlink" eval="True"/>
        </record>

        <!-- =========================== -->
        <!-- LEAVE (hr.leave) RULES      -->
        <!-- =========================== -->

        <!-- Employee: can only read/write own leave records -->
        <record id="rule_leave_employee_own" model="ir.rule">
            <field name="name">EmPay: Employee sees own leaves</field>
            <field name="model_id" ref="hr_holidays.model_hr_leave"/>
            <field name="domain_force">[('employee_id.user_id', '=', user.id)]</field>
            <field name="groups" eval="[(4, ref('empay_hrms.group_employee'))]"/>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="True"/>
            <field name="perm_create" eval="True"/>
            <field name="perm_unlink" eval="False"/>
        </record>

        <!-- HR Officer: can read/write all leave records -->
        <record id="rule_leave_hr_officer_all" model="ir.rule">
            <field name="name">EmPay: HR Officer sees all leaves</field>
            <field name="model_id" ref="hr_holidays.model_hr_leave"/>
            <field name="domain_force">[(1, '=', 1)]</field>
            <field name="groups" eval="[(4, ref('empay_hrms.group_hr_officer'))]"/>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="True"/>
            <field name="perm_create" eval="True"/>
            <field name="perm_unlink" eval="False"/>
        </record>

        <!-- Payroll Officer: can read/write all leave records (approve/reject) -->
        <record id="rule_leave_payroll_officer_all" model="ir.rule">
            <field name="name">EmPay: Payroll Officer sees all leaves</field>
            <field name="model_id" ref="hr_holidays.model_hr_leave"/>
            <field name="domain_force">[(1, '=', 1)]</field>
            <field name="groups" eval="[(4, ref('empay_hrms.group_payroll_officer'))]"/>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="True"/>
            <field name="perm_create" eval="True"/>
            <field name="perm_unlink" eval="False"/>
        </record>

        <!-- Admin: unrestricted leave access -->
        <record id="rule_leave_admin_all" model="ir.rule">
            <field name="name">EmPay: Admin full leave access</field>
            <field name="model_id" ref="hr_holidays.model_hr_leave"/>
            <field name="domain_force">[(1, '=', 1)]</field>
            <field name="groups" eval="[(4, ref('empay_hrms.group_admin'))]"/>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="True"/>
            <field name="perm_create" eval="True"/>
            <field name="perm_unlink" eval="True"/>
        </record>

        <!-- =========================== -->
        <!-- PAYSLIP (hr.payslip) RULES  -->
        <!-- =========================== -->

        <!-- Employee: can only read own payslips -->
        <record id="rule_payslip_employee_own" model="ir.rule">
            <field name="name">EmPay: Employee sees own payslips</field>
            <field name="model_id" ref="model_empay_payslip"/>
            <field name="domain_force">[('employee_id.user_id', '=', user.id)]</field>
            <field name="groups" eval="[(4, ref('empay_hrms.group_employee'))]"/>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="False"/>
            <field name="perm_create" eval="False"/>
            <field name="perm_unlink" eval="False"/>
        </record>

        <!-- Payroll Officer: can read/write all payslips -->
        <record id="rule_payslip_payroll_officer_all" model="ir.rule">
            <field name="name">EmPay: Payroll Officer sees all payslips</field>
            <field name="model_id" ref="model_empay_payslip"/>
            <field name="domain_force">[(1, '=', 1)]</field>
            <field name="groups" eval="[(4, ref('empay_hrms.group_payroll_officer'))]"/>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="True"/>
            <field name="perm_create" eval="True"/>
            <field name="perm_unlink" eval="False"/>
        </record>

        <!-- Admin: unrestricted payslip access -->
        <record id="rule_payslip_admin_all" model="ir.rule">
            <field name="name">EmPay: Admin full payslip access</field>
            <field name="model_id" ref="model_empay_payslip"/>
            <field name="domain_force">[(1, '=', 1)]</field>
            <field name="groups" eval="[(4, ref('empay_hrms.group_admin'))]"/>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="True"/>
            <field name="perm_create" eval="True"/>
            <field name="perm_unlink" eval="True"/>
        </record>

        <!-- =========================== -->
        <!-- PAYRUN (empay.payrun) RULES -->
        <!-- =========================== -->

        <!-- Payroll Officer: full payrun access -->
        <record id="rule_payrun_payroll_officer" model="ir.rule">
            <field name="name">EmPay: Payroll Officer manages payruns</field>
            <field name="model_id" ref="model_empay_payrun"/>
            <field name="domain_force">[(1, '=', 1)]</field>
            <field name="groups" eval="[(4, ref('empay_hrms.group_payroll_officer'))]"/>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="True"/>
            <field name="perm_create" eval="True"/>
            <field name="perm_unlink" eval="True"/>
        </record>

        <!-- Admin: full payrun access -->
        <record id="rule_payrun_admin" model="ir.rule">
            <field name="name">EmPay: Admin full payrun access</field>
            <field name="model_id" ref="model_empay_payrun"/>
            <field name="domain_force">[(1, '=', 1)]</field>
            <field name="groups" eval="[(4, ref('empay_hrms.group_admin'))]"/>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="True"/>
            <field name="perm_create" eval="True"/>
            <field name="perm_unlink" eval="True"/>
        </record>

        <!-- =========================== -->
        <!-- EMPLOYEE (hr.employee) RULES -->
        <!-- =========================== -->

        <!-- Employee: can read all employees (directory) but not modify -->
        <record id="rule_employee_employee_read" model="ir.rule">
            <field name="name">EmPay: Employee reads employee directory</field>
            <field name="model_id" ref="hr.model_hr_employee"/>
            <field name="domain_force">[(1, '=', 1)]</field>
            <field name="groups" eval="[(4, ref('empay_hrms.group_employee'))]"/>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="False"/>
            <field name="perm_create" eval="False"/>
            <field name="perm_unlink" eval="False"/>
        </record>

        <!-- HR Officer: can read/write all employees -->
        <record id="rule_employee_hr_officer_all" model="ir.rule">
            <field name="name">EmPay: HR Officer manages employees</field>
            <field name="model_id" ref="hr.model_hr_employee"/>
            <field name="domain_force">[(1, '=', 1)]</field>
            <field name="groups" eval="[(4, ref('empay_hrms.group_hr_officer'))]"/>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="True"/>
            <field name="perm_create" eval="True"/>
            <field name="perm_unlink" eval="False"/>
        </record>

        <!-- Admin: unrestricted employee access -->
        <record id="rule_employee_admin_all" model="ir.rule">
            <field name="name">EmPay: Admin full employee access</field>
            <field name="model_id" ref="hr.model_hr_employee"/>
            <field name="domain_force">[(1, '=', 1)]</field>
            <field name="groups" eval="[(4, ref('empay_hrms.group_admin'))]"/>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="True"/>
            <field name="perm_create" eval="True"/>
            <field name="perm_unlink" eval="True"/>
        </record>

    </data>
</odoo>
